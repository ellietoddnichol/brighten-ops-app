{
  "name": "brighten-ops-app",
  "version": "0.1.0",
  "private": true,
  "description": "Brighten solar installation operations platform – monorepo",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @brighten/database db:generate",
    "db:push": "pnpm --filter @brighten/database db:push",
    "db:seed": "pnpm --filter @brighten/database db:seed",
    "clean": "pnpm -r --parallel exec rm -rf dist .next .turbo node_modules/.cache"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
